{
  "name": "magi-melee",
  "version": "1.3.0",
  "description": "AI-powered Melee coaching from your Slippi replays",
  "main": "src/main/entry.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:renderer": "vite build",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder",
    "build:win": "tsc -p tsconfig.main.json && vite build && electron-builder --win",
    "build:mac": "tsc -p tsconfig.main.json && vite build && electron-builder --mac",
    "build:linux": "tsc -p tsconfig.main.json && vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "melee",
    "slippi",
    "coaching",
    "ai",
    "smash-bros"
  ],
  "author": {
    "name": "Bloodshed-Rain",
    "email": "268419293+Bloodshed-Rain@users.noreply.github.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.magi-melee.app",
    "productName": "MAGI",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/entry.js",
      "dist/main/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "."
      },
      {
        "from": "key.env",
        "to": "."
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Bloodshed-Rain",
      "repo": "MAGI"
    }
  },
  "dependencies": {
    "@slippi/slippi-js": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
