# MAGI API Configuration
# Copy this file to key.env and fill in your keys.
# key.env is gitignored and will NOT be committed.
#
# NOTE: OpenAI is handled by the MAGI proxy server — do NOT put an
# OpenAI key here. The proxy holds it server-side so it can't be
# extracted from the desktop app. See proxy/ for deployment.

GEMINI_API_KEY=your_key_here
